{
  "rules": [
    {
      "id": "rule-business-hours",
      "name": "Business Hours Routing",
      "description": "工作时间使用高性能路由",
      "priority": 90,
      "enabled": true,
      "conditions": [
        {
          "type": "time",
          "field": "hour",
          "op": "between",
          "value": "9-18"
        },
        {
          "type": "time",
          "field": "weekday",
          "op": "between",
          "value": "1-5"
        }
      ],
      "action": {
        "type": "route",
        "target": "high-performance-route"
      }
    },
    {
      "id": "rule-night-mode",
      "name": "Night Mode",
      "description": "夜间使用低成本路由",
      "priority": 85,
      "enabled": true,
      "conditions": [
        {
          "type": "time",
          "field": "hour",
          "op": "in",
          "value": "22,23,0,1,2,3,4,5,6"
        }
      ],
      "action": {
        "type": "route",
        "target": "cost-optimized-route"
      }
    },
    {
      "id": "rule-weekend",
      "name": "Weekend Routing",
      "description": "周末使用轻量级路由",
      "priority": 80,
      "enabled": true,
      "conditions": [
        {
          "type": "time",
          "field": "weekday",
          "op": "in",
          "value": "0,6"
        }
      ],
      "action": {
        "type": "route",
        "target": "lightweight-route"
      }
    }
  ]
}
