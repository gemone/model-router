# Model Router Environment Configuration
# 用于 1M+ 上下文模拟验证

# ============================================
# OpenAI 兼容 API 配置
# ============================================

# API Base URL (OpenAI 兼容服务)
# 例如:
# - OpenRouter: https://openrouter.ai/api/v1
# - Together AI: https://api.together.xyz/v1
# - DeepSeek: https://api.deepseek.com
# - 其他兼容服务: <provider-base-url>
OPENAI_API_BASE_URL=https://your-api-endpoint/v1

# API Key
OPENAI_API_KEY=sk-your-api-key-here

# 可选：指定使用的模型名称
# 如果不指定，将使用配置文件中的默认模型
MODEL_NAME=your-model-name

# ============================================
# 服务器配置
# ============================================
PORT=8080
HOST=0.0.0.0

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=debug
DEBUG=true

# ============================================
# 数据库配置
# ============================================
DB_PATH=./data/model-router.db

# ============================================
# 功能开关
# ============================================
ENABLE_STATS=true
ENABLE_FALLBACK=true
MAX_RETRIES=3

# ============================================
# 其他配置
# ============================================
# 管理员令牌（可选）
ADMIN_TOKEN=your-admin-token-here

# JWT 密钥（可选）
JWT_SECRET=model-router-secret-key

# 启用 CORS（可选）
ENABLE_CORS=true

# ============================================
# 持续对话测试配置 (1M+ Context)
# ============================================
# 持续测试的 Token 目标限制
CONTINUOUS_TOKEN_LIMIT=1000000

# 压缩阈值 (达到此 token 数时触发压缩)
CONTINUOUS_COMPRESSION_THRESHOLD=50000

# 每次对话的最大输出 tokens
CONTINUOUS_MAX_TOKENS_PER_TURN=8000

# 轮询间隔 (秒)
CONTINUOUS_POLL_INTERVAL=2

# 最大重试次数
CONTINUOUS_MAX_RETRIES=3

# 重试延迟 (秒)
CONTINUOUS_RETRY_DELAY=5

# 是否自动继续 (达到限制后是否继续)
CONTINUOUS_AUTO_CONTINUE=false

# 每个会话的最大轮次
CONTINUOUS_MAX_TURNS_PER_SESSION=10000

# 日志级别 (debug, info, warn, error)
CONTINUOUS_LOG_LEVEL=debug
