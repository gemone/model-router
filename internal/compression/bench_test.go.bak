		{"small", 100, 100, 10000},
		{"medium", 500, 100, 20000},
		{"large", 1000, 100, 30000},
	}

	b.Run("sliding_window", func(b *testing.B) {
		for _, tc := range testCases {
			b.Run(tc.name, func(b *testing.B) {
				messages := generateSyntheticMessages(tc.numMessages, tc.avgTokensMsg)
				session := &model.Session{
					ID:            "test-session",
