// BenchmarkCompressionRatio benchmarks and measures compression ratio
func BenchmarkCompressionRatio(b *testing.B) {
	adapter := &mockAdapter{}
	sw := NewSlidingWindowCompression(adapter)
	sc := NewSemanticClustering()
	ctx := context.Background()

	testCases := []struct {
		name          string
		numMessages   int
		avgTokensMsg  int
		targetRatio   float64 // 10:1 = 0.1
	}{
		{"200k_to_20k_10to1", 2000, 100, 0.1},
		{"100k_to_10k_10to1", 1000, 100, 0.1},
		{"50k_to_5k_10to1", 500, 100, 0.1},
	}

	b.Run("sliding_window", func(b *testing.B) {
		for _, tc := range testCases {
			b.Run(tc.name, func(b *testing.B) {
				messages := generateSyntheticMessages(tc.numMessages, tc.avgTokensMsg)
				session := &model.Session{
					ID:            "test-session",
					ContextWindow: tc.numMessages * tc.avgTokensMsg,
				}

				// Calculate original tokens
				originalTokens := 0
				for _, msg := range messages {
					originalTokens += estimateTokensBenchmark(msg.Content)
				}

				b.ResetTimer()
				for i := 0; i < b.N; i++ {
					result, err := sw.Compress(ctx, session, messages, int(float64(originalTokens)*tc.targetRatio))
					if err != nil {
						b.Fatalf("Compression failed: %v", err)
					}

					// Report compression ratio
					ratio := float64(result.CompressedTokens) / float64(result.OriginalTokens)
					b.ReportMetric(ratio, "ratio")
				}
			})
		}
	})

	b.Run("semantic_clustering", func(b *testing.B) {
		for _, tc := range testCases {
			b.Run(tc.name, func(b *testing.B) {
				messages := generateSyntheticMessages(tc.numMessages, tc.avgTokensMsg)

				internalMsgs := make([]Message, len(messages))
				for i, msg := range messages {
					internalMsgs[i] = Message{
						Role:    msg.Role,
						Content: fmt.Sprintf("%v", msg.Content),
						Tokens:  estimateTokensBenchmark(msg.Content),
					}
				}

				session := &Session{Messages: internalMsgs}

				// Calculate original tokens
				originalTokens := 0
				for _, msg := range internalMsgs {
					originalTokens += msg.Tokens
				}

				b.ResetTimer()
				for i := 0; i < b.N; i++ {
					result, err := sc.Compress(session, int(float64(originalTokens)*tc.targetRatio))
					if err != nil {
						b.Fatalf("Compression failed: %v", err)
					}

					// Report compression ratio
					ratio := float64(result.CompressedTokens) / float64(result.OriginalTokens)
					b.ReportMetric(ratio, "ratio")
				}
			})
		}
	})
}

// BenchmarkInformationRetention measures information retention after compression
// For now, uses a simple word overlap metric
func BenchmarkInformationRetention(b *testing.B) {
	adapter := &mockAdapter{}
	sw := NewSlidingWindowCompression(adapter)
	sc := NewSemanticClustering()
	ctx := context.Background()

	// Create test data with specific keywords to track
	messages := generateSyntheticMessages(500, 100)

	// Extract unique words from original for retention check
	originalWords := make(map[string]bool)
	for _, msg := range messages {
		content := fmt.Sprintf("%v", msg.Content)
		words := tokenizeContent(content)
		for _, word := range words {
			if len(word) > 3 {
				originalWords[word] = true
			}
		}
	}

	b.Run("sliding_window", func(b *testing.B) {
		session := &model.Session{
			ID:            "test-session",
			ContextWindow: 50000,
		}

		b.ResetTimer()
		for i := 0; i < b.N; i++ {
			result, err := sw.Compress(ctx, session, messages, 20000)
			if err != nil {
				b.Fatalf("Compression failed: %v", err)
			}

			// Calculate retention: words in compressed / words in original
			compressedWords := make(map[string]bool)
			for _, msg := range result.Messages {
				content := fmt.Sprintf("%v", msg.Content)
				words := tokenizeContent(content)
				for _, word := range words {
					compressedWords[word] = true
				}
			}

			// Include summary words
			if result.Summary != "" {
				words := tokenizeContent(result.Summary)
				for _, word := range words {
					compressedWords[word] = true
				}
			}

			retained := 0
			for word := range originalWords {
				if compressedWords[word] {
					retained++
				}
			}

			retention := float64(retained) / float64(len(originalWords)) * 100
			b.ReportMetric(retention, "retention_pct")
		}
	})

	b.Run("semantic_clustering", func(b *testing.B) {
		internalMsgs := make([]Message, len(messages))
		for i, msg := range messages {
			internalMsgs[i] = Message{
				Role:    msg.Role,
				Content: fmt.Sprintf("%v", msg.Content),
				Tokens:  estimateTokensBenchmark(msg.Content),
			}
		}

		session := &Session{Messages: internalMsgs}

		b.ResetTimer()
		for i := 0; i < b.N; i++ {
			result, err := sc.Compress(session, 10000)
			if err != nil {
				b.Fatalf("Compression failed: %v", err)
			}

			// Calculate retention
			compressedWords := make(map[string]bool)
			for _, msg := range result.Messages {
				words := tokenizeContent(msg.Content)
				for _, word := range words {
					compressedWords[word] = true
				}
			}

			retained := 0
			for word := range originalWords {
				if compressedWords[word] {
					retained++
				}
			}

			retention := float64(retained) / float64(len(originalWords)) * 100
			b.ReportMetric(retention, "retention_pct")
		}
	})
}

