// BenchmarkPipeline benchmarks the full compression pipeline
func BenchmarkPipeline(b *testing.B) {
	// Note: Pipeline requires Strategy interface which SemanticClustering doesn't implement yet.
	// Benchmark individual strategies instead.

	adapter := &mockAdapter{}
	sw := NewSlidingWindowCompression(adapter)
