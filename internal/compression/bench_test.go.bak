// generateSyntheticMessages creates test messages for benchmarking
func generateSyntheticMessages(count int, avgTokensPerMsg int) []model.Message {
	messages := make([]model.Message, count)
	roles := []string{"user", "assistant", "system"}

	topics := []string{
		"Implement compression algorithm for context window management",
		"Design database schema for session storage",
		"Configure API routing with load balancing",
		"Optimize token estimation for better performance",
		"Add unit tests for compression strategies",
		"Review and refactor authentication middleware",
		"Implement semantic clustering for message deduplication",
		"Configure monitoring and logging infrastructure",
		"Design rate limiting strategy for API endpoints",
		"Write documentation for compression pipeline",
	}

	for i := 0; i < count; i++ {
		role := roles[i%len(roles)]

		// Generate content with varying lengths
		content := ""
		tokensTarget := avgTokensPerMsg + (rand.Intn(avgTokensPerMsg/2) - avgTokensPerMsg/4)
		wordsPerToken := 4
		charsPerWord := 5

		numSentences := tokensTarget / 20
		if numSentences < 1 {
			numSentences = 1
		}

		for j := 0; j < numSentences; j++ {
			topic := topics[rand.Intn(len(topics))]
			content += fmt.Sprintf("%s: Discussion point %d with additional context about the implementation details and considerations. ", topic, j)
		}

		// Truncate to target size
		targetChars := tokensTarget * wordsPerToken * charsPerWord / wordsPerToken
		if len(content) > targetChars && targetChars > 0 {
			content = content[:targetChars]
		}

		messages[i] = model.Message{
			Role:    role,
			Content: content,
		}
	}

	return messages
}

// estimateTokensBenchmark estimates token count for content (benchmark version)
func estimateTokensBenchmark(content interface{}) int {
	var text string
	switch v := content.(type) {
	case string:
		text = v
	case []model.ContentPart:
		for _, part := range v {
			if part.Type == "text" {
				text += part.Text + " "
			}
		}
	default:
		text = fmt.Sprintf("%v", v)
	}
	return len(text) / 4
}

// Benchmark helpers

// BenchmarkSlidingWindowCompression benchmarks the sliding window compression strategy
func BenchmarkSlidingWindowCompression(b *testing.B) {
	adapter := &mockAdapter{}
	sw := NewSlidingWindowCompression(adapter)
	ctx := context.Background()

	testCases := []struct {
		name          string
		numMessages   int
		avgTokensMsg  int
		maxTokens     int
	}{
		{"small_50msg_100tokens", 50, 100, 20000},
		{"medium_200msg_100tokens", 200, 100, 20000},
		{"large_500msg_100tokens", 500, 100, 20000},
		{"xlarge_1000msg_100tokens", 1000, 100, 20000},
		{"longcontext_200msg_500tokens", 200, 500, 200000},
		{"verylong_500msg_500tokens", 500, 500, 200000},
	}

	for _, tc := range testCases {
		b.Run(tc.name, func(b *testing.B) {
			messages := generateSyntheticMessages(tc.numMessages, tc.avgTokensMsg)
			session := &model.Session{
				ID:            "test-session",
				ContextWindow: tc.maxTokens,
			}

			b.ResetTimer()
			for i := 0; i < b.N; i++ {
				_, err := sw.Compress(ctx, session, messages, tc.maxTokens)
				if err != nil {
					b.Fatalf("Compression failed: %v", err)
				}
			}
		})
	}
}

